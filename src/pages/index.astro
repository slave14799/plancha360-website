---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProductViewer3D from "../components/ProductViewer3D.astro";
import { images } from "../data/images";

const pageTitle = "Plancha360 — The grill you stand around, not behind.";
const pageDescription =
	"Plancha360 is a round, gas-fired plancha built for the way people actually want to cook outside — together. Everyone gathers around the same surface, food in the middle, drink in hand, host included.";
---

<BaseLayout title={pageTitle} description={pageDescription}>
	<header class="site-header">
		<div class="container header-inner">
			<a class="brand" href="#top" aria-label="Plancha360 home">
				<img src={images.logo} alt="Plancha360" width="36" height="36" />
				<span>Plancha360</span>
			</a>
			<nav aria-label="Primary">
				<a href="#product">Product</a>
				<a href="#story">The story</a>
				<a href="#waitlist">Waitlist</a>
			</nav>
		</div>
	</header>

	<main id="top">
		<section class="section hero">
			<div class="container hero-inner">
				<div class="hero-copy">
					<p class="eyebrow">Outdoor cooking, made social</p>
					<h1>The grill you stand around, not behind.</h1>
					<p class="lede">
						Plancha360 is a round, gas-fired plancha built for the way people actually want to cook
						outside — together. Everyone gathers around the same surface, food in the middle, drink
						in hand, host included.
					</p>
					<div class="hero-actions">
						<a class="button button-primary" href="#waitlist">Join the waitlist</a>
						<a class="button button-secondary" href="#product">See the product</a>
					</div>
				</div>
				<div class="hero-visual">
					<ProductViewer3D />
				</div>
			</div>
		</section>

		<!-- Sections from docs/plancha360-website-copy.md (intro, story, product,
		     models, value, sustainability, FAQ) are added in the next step,
		     after the design direction is approved. -->

		<section class="section waitlist" id="waitlist">
			<div class="container waitlist-inner">
				<div class="waitlist-copy">
					<p class="eyebrow">Launching August 2026</p>
					<h2>Be first when Plancha360 opens.</h2>
					<p class="lede">
						The first grills ship in August 2026, in a limited first batch. Join the waitlist to
						get early access, launch pricing, and updates as we go from prototype to product.
					</p>
				</div>

				<form class="waitlist-form" id="waitlist-form">
					<label>
						Name
						<input type="text" name="name" required />
					</label>
					<label>
						Email
						<input type="email" name="email" required />
					</label>
					<label class="full-width">
						What are you planning?
						<select name="intent">
							<option>Hosting at home</option>
							<option>Buying as a gift</option>
							<option>Event or rental interest</option>
							<option>Just curious</option>
						</select>
					</label>
					<label class="full-width">
						Message (optional)
						<textarea name="message" rows="5"></textarea>
					</label>
					<p class="waitlist-error" id="waitlist-error" hidden></p>
					<button class="button button-primary full-width" type="submit" id="waitlist-submit">
						Join the waitlist
					</button>
				</form>
				<div class="waitlist-success" id="waitlist-success" hidden>
					<p class="waitlist-success-title">You're on the list.</p>
					<p>We'll be in touch with early access and launch pricing before August 2026.</p>
				</div>
			</div>
		</section>
	</main>

	<footer class="site-footer">
		<div class="container">
			<p>Plancha360 — Outdoor cooking, made social.</p>
			<p class="muted">Made in Spain. Launching 2026.</p>
		</div>
	</footer>
</BaseLayout>

<style>
	/* ---------- Header ---------- */

	.site-header {
		padding-block: 24px;
	}

	.header-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 24px;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 12px;
		font-weight: 700;
		letter-spacing: 0.02em;
		text-decoration: none;
	}

	.brand img {
		width: 36px;
		height: 36px;
		object-fit: contain;
	}

	nav {
		display: flex;
		gap: 32px;
		flex-wrap: wrap;
	}

	nav a {
		font-size: 0.95rem;
		font-weight: 500;
		color: var(--color-muted);
		text-decoration: none;
		transition: color 0.2s ease;
	}

	nav a:hover {
		color: var(--color-text);
	}

	/* ---------- Hero ---------- */

	.hero {
		padding-top: clamp(40px, 6vw, 96px);
	}

	.hero-inner {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
		gap: clamp(32px, 5vw, 72px);
		align-items: center;
	}

	.hero-copy h1 {
		margin-bottom: 28px;
	}

	.hero-copy .lede {
		margin-bottom: 40px;
	}

	.hero-actions {
		display: flex;
		gap: 16px;
		flex-wrap: wrap;
	}

	/* ---------- Waitlist ---------- */

	.waitlist-inner {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
		gap: clamp(32px, 5vw, 72px);
		align-items: start;
	}

	.waitlist-copy h2 {
		margin-bottom: 24px;
	}

	.waitlist-form {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 20px;
	}

	.full-width {
		grid-column: 1 / -1;
	}

	.waitlist-error {
		grid-column: 1 / -1;
		color: var(--color-accent);
		font-size: 0.9rem;
		line-height: 1.5;
	}

	.waitlist-success {
		padding: 48px 0;
	}

	.waitlist-success-title {
		font-size: var(--text-h3);
		font-weight: 700;
		letter-spacing: -0.015em;
		margin-bottom: 12px;
	}

	.waitlist-success p:last-child {
		color: var(--color-muted);
	}

	/* ---------- Footer ---------- */

	.site-footer {
		padding-block: clamp(48px, 6vw, 80px);
		border-top: 1px solid rgba(26, 23, 20, 0.1);
	}

	.site-footer p:first-child {
		font-weight: 600;
		margin-bottom: 8px;
	}

	/* ---------- Responsive ---------- */

	@media (max-width: 980px) {
		.hero-inner,
		.waitlist-inner {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 640px) {
		.site-header {
			padding-block: 16px;
		}

		.header-inner {
			flex-direction: column;
			align-items: flex-start;
			gap: 16px;
		}

		nav {
			gap: 20px;
		}

		.waitlist-form {
			grid-template-columns: 1fr;
		}
	}
</style>

<script>
	const form = document.getElementById("waitlist-form") as HTMLFormElement | null;
	const submitBtn = document.getElementById("waitlist-submit") as HTMLButtonElement | null;
	const successEl = document.getElementById("waitlist-success") as HTMLElement | null;
	const errorEl = document.getElementById("waitlist-error") as HTMLElement | null;

	form?.addEventListener("submit", async (e) => {
		e.preventDefault();

		if (!form.checkValidity()) {
			form.reportValidity();
			return;
		}

		if (errorEl) errorEl.hidden = true;
		if (submitBtn) {
			submitBtn.disabled = true;
			submitBtn.textContent = "Sending…";
		}

		try {
			const res = await fetch("/api/waitlist", {
				method: "POST",
				body: new FormData(form),
			});

			const data = await res.json() as { success?: boolean; error?: string };

			if (res.ok && data.success) {
				form.hidden = true;
				if (successEl) successEl.hidden = false;
			} else {
				if (errorEl) {
					errorEl.textContent = (data as { error?: string }).error || "Something went wrong. Please try again.";
					errorEl.hidden = false;
				}
				if (submitBtn) {
					submitBtn.disabled = false;
					submitBtn.textContent = "Join the waitlist";
				}
			}
		} catch {
			if (errorEl) {
				errorEl.textContent = "Network error. Please try again.";
				errorEl.hidden = false;
			}
			if (submitBtn) {
				submitBtn.disabled = false;
				submitBtn.textContent = "Join the waitlist";
			}
		}
	});
</script>
