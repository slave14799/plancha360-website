---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProductViewer3D from "../components/ProductViewer3D.astro";
import { images } from "../data/images";

const pageTitle = "Plancha360 — The grill you stand around, not behind.";
const pageDescription =
	"Plancha360 is a round, gas-fired plancha built for the way people actually want to cook outside — together. Everyone gathers around the same surface, food in the middle, drink in hand, host included.";
---

<BaseLayout title={pageTitle} description={pageDescription}>
	<header class="site-header" id="site-header">
		<div class="container header-inner">
			<a class="brand" href="#top" aria-label="Plancha360 home">
				<img src={images.logo} alt="Plancha360" />
			</a>
			<nav aria-label="Primary">
				<a href="#product">Product</a>
				<a href="#story">The story</a>
				<a class="nav-pill" href="#waitlist">Waitlist</a>
			</nav>
		</div>
	</header>

	<main id="top">
		<section class="hero" id="hero">
			<div class="hero-bg" style={`background-image: url('${images.lifestyleCommunity}')`}></div>
			<div class="container hero-content">
				<h1>The grill you stand around, not behind.</h1>
				<p class="hero-subline">
					Plancha360 is a round, gas-fired plancha built for the way people actually want to cook
					outside — together. Everyone gathers around the same surface, food in the middle, drink
					in hand, host included.
				</p>
				<div class="hero-actions">
					<a class="button button-primary" href="#waitlist">Join the waitlist</a>
					<a class="button button-ghost" href="#product">See the product</a>
				</div>
			</div>
		</section>

		<section class="section story" id="story">
			<div class="container story-inner">
				<header class="story-header">
					<p class="eyebrow">Where it started</p>
					<h2>Ten years of better evenings.</h2>
				</header>
				<div class="story-body">
					<p>
						Plancha360 didn't start as a business. It started in my parents' garden in Germany. Ten
						years ago my father had a round plancha built by a metalworker who made them as a hobby.
						Every birthday, every gathering, every time we had people over, that grill was the center
						of the evening.
					</p>
					<p>
						What stuck with me wasn't the food. It was that nobody was left out. You could cook and
						talk at the same time, beer in hand, everyone gathered around the same surface instead of
						one person stranded at a rectangular grill while the party moved on without them.
					</p>
					<p>
						When I moved to Barcelona in 2022, I fell for the Spanish way of eating — long evenings
						outside, tapas that last for hours, food as the reason everyone stays at the table. And
						it struck me that this grill, the one we'd loved for a decade in Germany, belonged here.
						A product made for exactly this kind of evening, in a country that lives for them.
					</p>
					<p>
						Charcoal grills are banned in many city centers because of the smoke. Barcelona is full
						of rooftop terraces with nowhere to cook. Plancha360 runs on gas — fast to heat, low
						smoke, easy to clean — which makes social outdoor cooking possible even in the middle of
						a city.
					</p>
					<p>That's why Plancha360 exists. To bring a German garden secret to Spanish evenings.</p>
					<p class="story-signature">— Tim, Founder</p>
				</div>
			</div>
		</section>

		<section class="section models" id="product">
			<div class="container">
				<h2 class="models-headline">Two sizes. Same idea.</h2>
				<div class="product-viewer">
					<ProductViewer3D />
				</div>
				<div class="models-grid">
					<article class="model-card">
						<img src={images.model700} alt="Plancha360 Model 700" loading="lazy" />
						<h3>Model 700</h3>
						<p>
							70 cm cooking surface. Built for terraces, smaller groups, and easier setups. Comes
							with two grilling spatulas.
						</p>
						<p class="model-price">From €500</p>
					</article>
					<article class="model-card">
						<img src={images.model900} alt="Plancha360 Model 900" loading="lazy" />
						<h3>Model 900</h3>
						<p>
							90 cm cooking surface. Built for bigger gatherings and serious hosting. Comes with
							four grilling spatulas.
						</p>
						<p class="model-price">From €650</p>
					</article>
				</div>
				<p class="models-note muted">
					Both ship as a complete grill with a paella burner included. Already own a compatible
					burner? Order without one for less. A stainless-steel cover is available separately for
					year-round outdoor storage.
				</p>
			</div>
		</section>

		<section class="section value">
			<div class="container value-inner">
				<div class="value-copy">
					<h2>Made for people who host.</h2>
					<p class="lede">
						If you love being the one who brings people together — long dinners outside, friends in
						the garden, food that turns into an evening — this is built for you. Not a luxury object
						to show off. A tool that makes the gatherings you already love better.
					</p>
				</div>
				<ul class="value-points">
					<li>
						<h3>Social by design</h3>
						<p>Cook and stay in the conversation at the same time.</p>
					</li>
					<li>
						<h3>Practical enough for real life</h3>
						<p>Fast heat, low smoke, easy cleanup. Use it on a Tuesday, not just a birthday.</p>
					</li>
					<li>
						<h3>Made to last</h3>
						<p>Solid steel, made in Spain, built to outlive every grill you've owned.</p>
					</li>
				</ul>
			</div>
		</section>

		<section class="section waitlist" id="waitlist">
			<div class="container">
				<p class="batch-counter" id="batch-counter" hidden></p>
				<div class="incentive-callout">
					<svg
						class="incentive-icon"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="1.8"
						stroke-linejoin="round"
						aria-hidden="true"
					>
						<path d="M20.6 13.4 13.4 20.6a2 2 0 0 1-2.8 0L3 13V3h10l7.6 7.6a2 2 0 0 1 0 2.8Z" />
						<circle cx="7.5" cy="7.5" r="1.5" fill="currentColor" stroke="none" />
					</svg>
					<div>
						<p class="incentive-title">€50 off for waitlist members</p>
						<p class="incentive-sub">
							Everyone who signs up gets €50 off the launch price. Applied automatically — no
							code needed.
						</p>
					</div>
				</div>
				<div class="waitlist-inner">
				<div class="waitlist-copy">
					<p class="eyebrow">Launching August 2026</p>
					<h2>Be first when Plancha360 opens.</h2>
					<p class="lede">
						The first grills ship in August 2026, in a limited first batch. Join the waitlist to
						get early access, launch pricing, and updates as we go from prototype to product.
					</p>
				</div>

				<form class="waitlist-form" id="waitlist-form">
					<label>
						Name
						<input type="text" name="name" required />
					</label>
					<label>
						Email
						<input type="email" name="email" required />
					</label>
					<label class="full-width">
						What are you planning?
						<select name="intent">
							<option>Hosting at home</option>
							<option>Buying as a gift</option>
							<option>Event or rental interest</option>
							<option>Just curious</option>
						</select>
					</label>
					<label class="full-width">
						Message (optional)
						<textarea name="message" rows="5"></textarea>
					</label>
					<p class="waitlist-error" id="waitlist-error" hidden></p>
					<button class="button button-primary full-width" type="submit" id="waitlist-submit">
						Join the waitlist
					</button>
				</form>
				<div class="waitlist-success" id="waitlist-success" hidden>
					<p class="waitlist-success-title">You're on the list.</p>
					<p>We'll be in touch with early access and launch pricing before August 2026.</p>
				</div>
				</div>
			</div>
		</section>
	</main>

	<footer class="site-footer">
		<div class="container">
			<p>Plancha360 — Outdoor cooking, made social.</p>
			<p class="muted">Made in Spain. Launching 2026.</p>
		</div>
	</footer>
</BaseLayout>

<style>
	/* ---------- Header ---------- */

	.site-header {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 100;
		padding-block: 16px;
		background: transparent;
		transition: background-color 0.3s ease, box-shadow 0.3s ease;
	}

	.site-header.scrolled {
		background: var(--color-bg);
		box-shadow: 0 1px 12px rgba(26, 23, 20, 0.08);
	}

	.header-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 24px;
	}

	.brand {
		display: inline-flex;
		align-items: center;
	}

	.brand img {
		height: 32px;
		width: auto;
	}

	nav {
		display: flex;
		align-items: center;
		gap: 32px;
		flex-wrap: wrap;
	}

	nav a:not(.nav-pill) {
		font-size: 0.95rem;
		font-weight: 500;
		color: rgba(255, 255, 255, 0.85);
		text-decoration: none;
		transition: color 0.2s ease;
	}

	nav a:not(.nav-pill):hover {
		color: #ffffff;
	}

	.site-header.scrolled nav a:not(.nav-pill) {
		color: var(--color-muted);
	}

	.site-header.scrolled nav a:not(.nav-pill):hover {
		color: var(--color-text);
	}

	.nav-pill {
		display: inline-flex;
		align-items: center;
		padding: 8px 20px;
		font-size: 0.9rem;
		font-weight: 600;
		color: #ffffff;
		background: var(--color-accent);
		border-radius: 999px;
		text-decoration: none;
		transition: background-color 0.2s ease;
	}

	.nav-pill:hover {
		background: #9c4523;
	}

	/* ---------- Hero ---------- */

	.hero {
		position: relative;
		min-height: 100vh;
		min-height: 100svh;
		display: flex;
		align-items: center;
		justify-content: center;
		background: #1a1714;
		overflow: hidden;
	}

	.hero-bg {
		position: absolute;
		inset: 0;
		background-size: cover;
		background-position: center;
	}

	.hero-bg::after {
		content: "";
		position: absolute;
		inset: 0;
		background: rgba(0, 0, 0, 0.45);
	}

	.hero-content {
		position: relative;
		text-align: center;
		padding-block: 120px;
	}

	.hero-content h1 {
		font-size: clamp(3rem, 7vw, 6rem);
		font-weight: 700;
		letter-spacing: -0.03em;
		color: #ffffff;
		margin-bottom: 28px;
	}

	.hero-subline {
		font-size: var(--text-lede);
		line-height: 1.6;
		color: rgba(255, 255, 255, 0.7);
		max-width: 65ch;
		margin-inline: auto;
		margin-bottom: 40px;
	}

	.hero-actions {
		display: flex;
		gap: 16px;
		flex-wrap: wrap;
		justify-content: center;
	}

	.button-ghost {
		background: transparent;
		color: #ffffff;
		border-color: rgba(255, 255, 255, 0.7);
	}

	.button-ghost:hover {
		border-color: #ffffff;
		background: rgba(255, 255, 255, 0.1);
	}

	/* Anchored sections clear the fixed header */
	.models,
	.story,
	.waitlist {
		scroll-margin-top: 72px;
	}

	/* ---------- Story ---------- */

	.story-inner {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(0, 1.4fr);
		gap: clamp(32px, 5vw, 72px);
		align-items: start;
	}

	.story-header h2 {
		margin-bottom: 0;
	}

	.story-body p {
		margin-bottom: 24px;
		color: var(--color-muted);
	}

	.story-body p:first-child {
		color: var(--color-text);
	}

	.story-signature {
		font-weight: 600;
		color: var(--color-text);
	}

	.story-body p:last-child {
		margin-bottom: 0;
	}

	/* ---------- Models ---------- */

	.models-headline {
		margin-bottom: clamp(32px, 4vw, 56px);
	}

	.product-viewer {
		margin-bottom: clamp(40px, 5vw, 72px);
	}

	.models-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: clamp(24px, 3vw, 40px);
	}

	.model-card {
		background: var(--color-surface);
		padding: clamp(24px, 3vw, 40px);
		border-radius: 4px;
	}

	.model-card img {
		width: 100%;
		aspect-ratio: 4 / 3;
		object-fit: contain;
		margin-bottom: 24px;
	}

	.model-card h3 {
		margin-bottom: 12px;
	}

	.model-card p {
		color: var(--color-muted);
	}

	.model-card .model-price {
		margin-top: 16px;
		font-weight: 700;
		color: var(--color-accent);
	}

	.models-note {
		margin-top: clamp(24px, 3vw, 40px);
		font-size: 0.95rem;
	}

	/* ---------- Value ---------- */

	.value-inner {
		display: grid;
		grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr);
		gap: clamp(32px, 5vw, 72px);
		align-items: start;
	}

	.value-copy h2 {
		margin-bottom: 24px;
	}

	.value-points {
		list-style: none;
		display: grid;
		gap: 32px;
	}

	.value-points h3 {
		margin-bottom: 8px;
	}

	.value-points p {
		color: var(--color-muted);
	}

	/* ---------- Waitlist ---------- */

	.waitlist-inner {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
		gap: clamp(32px, 5vw, 72px);
		align-items: start;
	}

	.waitlist-copy h2 {
		margin-bottom: 24px;
	}

	.batch-counter {
		font-size: 0.95rem;
		font-weight: 600;
		color: var(--color-muted);
		margin-bottom: 16px;
	}

	.incentive-callout {
		display: flex;
		align-items: center;
		gap: clamp(20px, 3vw, 32px);
		background: var(--color-accent);
		color: #ffffff;
		padding: clamp(28px, 4vw, 44px);
		border-radius: 16px;
		margin-bottom: clamp(40px, 6vw, 64px);
	}

	.incentive-icon {
		width: clamp(40px, 5vw, 56px);
		height: clamp(40px, 5vw, 56px);
		flex-shrink: 0;
	}

	.incentive-title {
		font-size: clamp(1.3rem, 2.5vw, 1.75rem);
		font-weight: 700;
		letter-spacing: -0.015em;
		margin-bottom: 8px;
	}

	.incentive-sub {
		font-size: 1.05rem;
		line-height: 1.6;
		opacity: 0.92;
		max-width: 65ch;
	}

	.waitlist-form {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 20px;
	}

	/* display: grid above beats the UA rule for [hidden]; restore it so
	   form.hidden = true actually hides the form after submission */
	.waitlist-form[hidden] {
		display: none;
	}

	.full-width {
		grid-column: 1 / -1;
	}

	.waitlist-error {
		grid-column: 1 / -1;
		color: var(--color-accent);
		font-size: 0.9rem;
		line-height: 1.5;
	}

	.waitlist-success {
		padding: 48px 0;
	}

	.waitlist-success-title {
		font-size: var(--text-h3);
		font-weight: 700;
		letter-spacing: -0.015em;
		margin-bottom: 12px;
	}

	.waitlist-success p:last-child {
		color: var(--color-muted);
	}

	/* ---------- Footer ---------- */

	.site-footer {
		padding-block: clamp(48px, 6vw, 80px);
		border-top: 1px solid rgba(26, 23, 20, 0.1);
	}

	.site-footer p:first-child {
		font-weight: 600;
		margin-bottom: 8px;
	}

	/* ---------- Responsive ---------- */

	@media (max-width: 980px) {
		.story-inner,
		.value-inner,
		.waitlist-inner {
			grid-template-columns: 1fr;
		}

		.models-grid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 640px) {
		.site-header {
			padding-block: 12px;
		}

		nav {
			gap: 16px;
		}

		.waitlist-form {
			grid-template-columns: 1fr;
		}

		.incentive-callout {
			flex-direction: column;
			align-items: flex-start;
		}
	}
</style>

<script>
	const header = document.getElementById("site-header");
	const hero = document.getElementById("hero");

	const updateHeader = () => {
		if (!header || !hero) return;
		header.classList.toggle("scrolled", window.scrollY > hero.offsetHeight - 72);
	};

	updateHeader();
	window.addEventListener("scroll", updateHeader, { passive: true });
	window.addEventListener("resize", updateHeader, { passive: true });

	const form = document.getElementById("waitlist-form") as HTMLFormElement | null;
	const submitBtn = document.getElementById("waitlist-submit") as HTMLButtonElement | null;
	const successEl = document.getElementById("waitlist-success") as HTMLElement | null;
	const errorEl = document.getElementById("waitlist-error") as HTMLElement | null;
	const counterEl = document.getElementById("batch-counter") as HTMLElement | null;

	const BATCH_SIZE = 20;

	// Shows only a real count from the API; stays hidden if none is available.
	const loadBatchCount = async () => {
		if (!counterEl) return;
		try {
			const res = await fetch("/api/waitlist");
			if (!res.ok) return;
			const data = (await res.json()) as { count?: number | null };
			if (typeof data.count !== "number") return;
			counterEl.textContent =
				data.count === 0
					? `${BATCH_SIZE} first-batch spots available`
					: `${Math.min(data.count, BATCH_SIZE)} of ${BATCH_SIZE} first-batch spots reserved`;
			counterEl.hidden = false;
		} catch {
			// no count available — leave the line hidden
		}
	};

	loadBatchCount();

	form?.addEventListener("submit", async (e) => {
		e.preventDefault();

		if (!form.checkValidity()) {
			form.reportValidity();
			return;
		}

		if (errorEl) errorEl.hidden = true;
		if (submitBtn) {
			submitBtn.disabled = true;
			submitBtn.textContent = "Sending…";
		}

		try {
			const res = await fetch("/api/waitlist", {
				method: "POST",
				body: new FormData(form),
			});

			const data = await res.json() as { success?: boolean; error?: string };

			if (res.ok && data.success) {
				form.hidden = true;
				if (successEl) successEl.hidden = false;
				loadBatchCount();
			} else {
				if (errorEl) {
					errorEl.textContent = (data as { error?: string }).error || "Something went wrong. Please try again.";
					errorEl.hidden = false;
				}
				if (submitBtn) {
					submitBtn.disabled = false;
					submitBtn.textContent = "Join the waitlist";
				}
			}
		} catch {
			if (errorEl) {
				errorEl.textContent = "Network error. Please try again.";
				errorEl.hidden = false;
			}
			if (submitBtn) {
				submitBtn.disabled = false;
				submitBtn.textContent = "Join the waitlist";
			}
		}
	});
</script>
