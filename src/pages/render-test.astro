---
const title = "Plancha360 render test";
const views = [
	{ label: "Front three-quarter", orbit: "35deg 75deg 2.8m" },
	{ label: "Left three-quarter", orbit: "145deg 75deg 2.8m" },
	{ label: "Rear three-quarter", orbit: "235deg 75deg 2.8m" },
];
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title}</title>
		<script type="module" src="https://ajax.googleapis.com/ajax/libs/model-viewer/3.4.0/model-viewer.min.js"></script>
	</head>
	<body>
		<main class="stage">
			{views.map((view) => (
				<section class="panel">
					<div class="label">{view.label}</div>
					<model-viewer
						src="/3d/plancha360.glb"
						camera-orbit={view.orbit}
						camera-target="0m 0m 0m"
						disable-pan
						shadow-intensity="1"
						environment-image="neutral"
						interaction-prompt="none"
						reveal="auto"
						alt={`Plancha360 3D product model - ${view.label}`}
						field-of-view="30deg"
					></model-viewer>
				</section>
			))}
		</main>
		<script type="module">
			const palette = [
				{ c: [0.07, 0.08, 0.09, 1], m: 1, r: 0.56 },
				{ c: [0.07, 0.08, 0.09, 1], m: 1, r: 0.56 },
				{ c: [0.48, 0.5, 0.52, 1], m: 1, r: 0.7 },
				{ c: [0.48, 0.5, 0.52, 1], m: 1, r: 0.7 },
				{ c: [0.48, 0.5, 0.52, 1], m: 1, r: 0.7 },
				{ c: [0.07, 0.08, 0.09, 1], m: 1, r: 0.56 },
				{ c: [0.54, 0.55, 0.56, 1], m: 1, r: 0.42 },
				{ c: [0.54, 0.55, 0.56, 1], m: 1, r: 0.42 },
				{ c: [0.62, 0.52, 0.23, 1], m: 1, r: 0.5 },
				{ c: [0.48, 0.5, 0.52, 1], m: 1, r: 0.7 },
				{ c: [0.54, 0.55, 0.56, 1], m: 1, r: 0.42 },
				{ c: [0.54, 0.55, 0.56, 1], m: 1, r: 0.42 },
			];

			function applyMaterialPass(viewer) {
				if (!viewer.model?.materials?.length) return false;
				viewer.model.materials.forEach((mat, i) => {
					const p = palette[i] ?? palette[2];
					mat.pbrMetallicRoughness.setBaseColorFactor(p.c);
					mat.pbrMetallicRoughness.setMetallicFactor(p.m);
					mat.pbrMetallicRoughness.setRoughnessFactor(p.r);
					mat.setDoubleSided(true);
				});
				return true;
			}

			document.querySelectorAll("model-viewer").forEach((viewer) => {
				if (!applyMaterialPass(viewer)) {
					viewer.addEventListener("load", () => applyMaterialPass(viewer), { once: true });
				}
			});
		</script>
	</body>
</html>

<style>
	body {
		margin: 0;
		background: radial-gradient(circle at 50% 40%, #f7efe5 0%, #e7dccd 44%, #c8b79f 100%);
	}

	.stage {
		width: 100vw;
		min-height: 100vh;
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 16px;
		padding: 16px;
		box-sizing: border-box;
		overflow: hidden;
	}

	.panel {
		display: grid;
		grid-template-rows: auto 1fr;
		min-height: calc(100vh - 32px);
		background: rgba(255, 255, 255, 0.18);
		border: 1px solid rgba(65, 50, 30, 0.15);
		border-radius: 18px;
		backdrop-filter: blur(8px);
		padding: 12px;
		box-sizing: border-box;
	}

	.label {
		font: 600 14px/1.2 system-ui, sans-serif;
		letter-spacing: 0.02em;
		color: rgba(54, 39, 24, 0.8);
		padding: 4px 6px 10px;
	}

	model-viewer {
		width: 100%;
		height: 100%;
		background: transparent;
		--poster-color: transparent;
		--progress-bar-color: #b6532a;
		--progress-mask: transparent;
	}

	@media (max-width: 1100px) {
		.stage {
			grid-template-columns: 1fr;
		}
		.panel {
			min-height: 70vh;
		}
	}
</style>
