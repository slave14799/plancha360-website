---
const { class: className = "" } = Astro.props;
---

<div class={`viewer-shell ${className}`.trim()}>
	<div class="viewer-frame">
		<div class="viewer-badge">Interactive 3D prototype</div>
	<model-viewer
		src="/3d/plancha360.glb"
		camera-controls
		auto-rotate
		shadow-intensity="1"
		environment-image="neutral"
		interaction-prompt="none"
		ar-status="not-presenting"
		reveal="auto"
		alt="Plancha360 3D product model"
	>
	</model-viewer>
	</div>

	<div class="viewer-caption">
		<p class="eyebrow">Interactive 3D preview</p>
		<p>Rotate the model to inspect the form, proportions, and steel construction while the photography catches up.</p>
		<div class="viewer-tags" aria-label="3D viewer highlights">
			<span>360° inspection</span>
			<span>Steel build</span>
			<span>Prototype</span>
		</div>
	</div>
</div>

<style>
	.viewer-shell {
		display: grid;
		gap: 16px;
		padding: 16px;
		border-radius: 32px;
		background: linear-gradient(160deg, rgba(47, 75, 69, 0.13), rgba(182, 83, 42, 0.08));
		border: 1px solid rgba(29, 24, 21, 0.12);
		box-shadow: 0 28px 88px rgba(63, 40, 20, 0.14);
	}

	.viewer-frame {
		position: relative;
		border-radius: 28px;
		padding: 14px;
		background: linear-gradient(180deg, rgba(42, 32, 28, 0.96) 0%, rgba(77, 56, 41, 0.93) 32%, rgba(187, 160, 129, 0.52) 100%);
		overflow: hidden;
	}

	.viewer-frame::before {
		content: "";
		position: absolute;
		inset: 10px;
		border-radius: 22px;
		background: radial-gradient(circle at 50% 38%, rgba(255, 255, 255, 0.85), rgba(255, 255, 255, 0) 55%);
		pointer-events: none;
	}

	.viewer-badge {
		position: absolute;
		top: 18px;
		left: 18px;
		z-index: 2;
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 8px 12px;
		border-radius: 999px;
		background: rgba(29, 24, 21, 0.78);
		color: #fff6ee;
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		box-shadow: 0 16px 30px rgba(29, 24, 21, 0.18);
	}

	model-viewer {
		position: relative;
		z-index: 1;
		width: 100%;
		min-height: 520px;
		height: clamp(520px, 62vw, 760px);
		background: radial-gradient(circle at 50% 36%, rgba(255, 244, 229, 0.98), rgba(122, 90, 67, 0.92) 58%, rgba(36, 27, 23, 1) 100%);
		border: 1px solid rgba(255, 255, 255, 0.12);
		border-radius: 24px;
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.55), 0 18px 40px rgba(21, 16, 14, 0.38);
		--poster-color: transparent;
		--progress-bar-color: #b6532a;
		--progress-mask: transparent;
	}

	.viewer-caption {
		display: grid;
		gap: 12px;
		padding: 4px 4px 0;
	}

	.viewer-caption p {
		margin: 0;
		color: var(--muted);
		line-height: 1.6;
	}

	.viewer-caption .eyebrow {
		margin-bottom: 8px;
	}

	.viewer-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
	}

	.viewer-tags span {
		display: inline-flex;
		align-items: center;
		padding: 8px 12px;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.74);
		border: 1px solid rgba(29, 24, 21, 0.08);
		font-size: 0.82rem;
		font-weight: 600;
		color: var(--text);
	}

	@media (max-width: 980px) {
		.viewer-shell {
			padding: 14px;
		}

		model-viewer {
			min-height: 420px;
			height: 520px;
		}
	}

	@media (max-width: 640px) {
		.viewer-shell {
			padding: 12px;
			border-radius: 26px;
		}

		.viewer-frame {
			padding: 10px;
			border-radius: 22px;
		}

		model-viewer {
			min-height: 320px;
			height: 360px;
			border-radius: 18px;
		}
	}
</style>
