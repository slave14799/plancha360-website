---
const { class: className = "" } = Astro.props;
---

<div class={`viewer-shell ${className}`.trim()}>
	<div class="viewer-frame">
		<model-viewer
			src="/3d/plancha360.glb"
			scale="0.001 0.001 0.001"
			camera-controls
			disable-pan
			camera-orbit="45deg 65deg 3.8m"
			min-camera-orbit="auto auto 1.5m"
			max-camera-orbit="auto auto 6m"
			shadow-intensity="1"
			environment-image="neutral"
			interaction-prompt="none"
			reveal="auto"
			alt="Plancha360 3D product model"
			field-of-view="30deg"
		></model-viewer>
	</div>
</div>

<script type="module">
	const palette = [
		{ c: [0.07, 0.08, 0.09, 1], m: 1, r: 0.56 },
		{ c: [0.07, 0.08, 0.09, 1], m: 1, r: 0.56 },
		{ c: [0.48, 0.5, 0.52, 1], m: 1, r: 0.7 },
		{ c: [0.48, 0.5, 0.52, 1], m: 1, r: 0.7 },
		{ c: [0.48, 0.5, 0.52, 1], m: 1, r: 0.7 },
		{ c: [0.07, 0.08, 0.09, 1], m: 1, r: 0.56 },
		{ c: [0.54, 0.55, 0.56, 1], m: 1, r: 0.42 },
		{ c: [0.54, 0.55, 0.56, 1], m: 1, r: 0.42 },
		{ c: [0.62, 0.52, 0.23, 1], m: 1, r: 0.5 },
		{ c: [0.48, 0.5, 0.52, 1], m: 1, r: 0.7 },
		{ c: [0.54, 0.55, 0.56, 1], m: 1, r: 0.42 },
		{ c: [0.54, 0.55, 0.56, 1], m: 1, r: 0.42 },
	];

	function applyMaterialPass(viewer) {
		if (!viewer?.model?.materials?.length) return false;

		viewer.model.materials.forEach((mat, i) => {
			const p = palette[i] ?? palette[2];
			mat.pbrMetallicRoughness.setBaseColorFactor(p.c);
			mat.pbrMetallicRoughness.setMetallicFactor(p.m);
			mat.pbrMetallicRoughness.setRoughnessFactor(p.r);
			mat.setDoubleSided(true);
		});

		return true;
	}

	const viewer = document.querySelector("model-viewer");
	if (!viewer) {
		throw new Error("Plancha360 viewer element not found");
	}

	let angle = 0;
	let interacting = false;

	viewer.addEventListener("mousedown", () => {
		interacting = true;
	});
	viewer.addEventListener("touchstart", () => {
		interacting = true;
	}, { passive: true });
	viewer.addEventListener("mouseup", () => {
		interacting = false;
	});
	viewer.addEventListener("touchend", () => {
		interacting = false;
	});

	function tick() {
		if (!interacting) {
			angle = (angle + 0.08) % 360;
			viewer.cameraOrbit = `${angle}deg 65deg 3.8m`;
		}
		requestAnimationFrame(tick);
	}

	if (!applyMaterialPass(viewer)) {
		viewer.addEventListener("load", () => {
			applyMaterialPass(viewer);
			tick();
		}, { once: true });
	} else {
		tick();
	}
</script>

<style>
	.viewer-shell {
		display: block;
		padding: 0;
		background: transparent;
		border: 0;
		box-shadow: none;
	}

	.viewer-frame {
		position: relative;
		padding: 14px;
		border-radius: 26px;
		overflow: hidden;
		background: linear-gradient(180deg, rgba(42, 32, 28, 0.96) 0%, rgba(77, 56, 41, 0.94) 34%, rgba(187, 160, 129, 0.52) 100%);
	}

	.viewer-frame::before {
		content: "";
		position: absolute;
		inset: 12px;
		border-radius: 20px;
		background: radial-gradient(circle at 50% 38%, rgba(255, 255, 255, 0.84), rgba(255, 255, 255, 0) 55%);
		pointer-events: none;
	}

	model-viewer {
		position: relative;
		z-index: 1;
		display: block;
		width: 100%;
		min-height: 520px;
		height: clamp(520px, 62vw, 760px);
		border-radius: 22px;
		border: 1px solid rgba(255, 255, 255, 0.12);
		background: radial-gradient(circle at 50% 36%, rgba(255, 244, 229, 0.98), rgba(122, 90, 67, 0.92) 58%, rgba(36, 27, 23, 1) 100%);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.5), 0 18px 40px rgba(21, 16, 14, 0.36);
		--poster-color: transparent;
		--progress-bar-color: #b6532a;
		--progress-mask: transparent;
	}

	@media (max-width: 980px) {
		.viewer-shell {
			padding: 0;
		}

		model-viewer {
			min-height: 420px;
			height: 520px;
		}
	}

	@media (max-width: 640px) {
		.viewer-shell {
			padding: 0;
			border-radius: 26px;
		}

		.viewer-frame {
			padding: 10px;
			border-radius: 22px;
		}

		model-viewer {
			min-height: 320px;
			height: 360px;
			border-radius: 18px;
		}
	}
</style>
