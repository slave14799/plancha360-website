---
const { class: className = "" } = Astro.props;
---

<div class={`viewer-shell ${className}`.trim()}>
	<model-viewer
		src="/3d/plancha360.glb"
		camera-controls
		auto-rotate
		shadow-intensity="1"
		environment-image="neutral"
		interaction-prompt="none"
		ar-status="not-presenting"
		reveal="auto"
		alt="Plancha360 3D product model"
	>
	</model-viewer>

	<div class="viewer-caption">
		<p class="eyebrow">Interactive 3D preview</p>
		<p>Rotate the model to inspect the form, proportions, and steel construction before real photography is available.</p>
	</div>
</div>

<style>
	.viewer-shell {
		display: grid;
		gap: 14px;
	}

	model-viewer {
		width: 100%;
		min-height: 520px;
		height: clamp(520px, 62vw, 760px);
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.35), rgba(255, 250, 244, 0.18));
		border: 1px solid rgba(29, 24, 21, 0.12);
		border-radius: 28px;
		box-shadow: 0 26px 90px rgba(63, 40, 20, 0.14);
		--poster-color: transparent;
		--progress-bar-color: #b6532a;
		--progress-mask: transparent;
	}

	.viewer-caption {
		padding: 16px 4px 0;
	}

	.viewer-caption p {
		margin: 0;
		color: var(--muted);
		line-height: 1.6;
	}

	.viewer-caption .eyebrow {
		margin-bottom: 8px;
	}

	@media (max-width: 980px) {
		model-viewer {
			min-height: 420px;
			height: 520px;
		}
	}

	@media (max-width: 640px) {
		model-viewer {
			min-height: 320px;
			height: 360px;
			border-radius: 22px;
		}
	}
</style>
